{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true,
    "lib": ["ESNext"],
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "bin/**/*.js"],
  "exclude": ["node_modules", "dist", "scripts"]
}
